{
  "slug": "emphasis",
  "nameZh": "強調句式",
  "nameEn": "Emphasis Patterns",
  "description": "It is ... that / Not only ... but also 等強調結構。",
  "difficulty": "medium",
  "contentKind": "sentence-pattern",
  "entries": [
    {
      "id": "emphasis-001",
      "kind": "sentence-pattern",
      "term": "It is ... that ...",
      "meaningZh": "正是...使得...",
      "difficulty": 2,
      "example": "It is technology that has transformed society.",
      "synonyms": ["What ... is ...", "The thing that...", "The fact that"]
    },
    {
      "id": "emphasis-002",
      "kind": "sentence-pattern",
      "term": "Not only ... but also ...",
      "meaningZh": "不僅...而且...",
      "difficulty": 2,
      "example": "Not only is education important, but also it shapes character.",
      "synonyms": ["Both ... and ...", "... as well as ...", "Furthermore, ..."]
    },
    {
      "id": "emphasis-003",
      "kind": "sentence-pattern",
      "term": "Such is the ... that ...",
      "meaningZh": "如此...以至於...",
      "difficulty": 3,
      "example": "Such is the impact of climate change that nations must act.",
      "synonyms": ["So ... that ...", "To such an extent that", "The ... is so ..."]
    },
    {
      "id": "emphasis-004",
      "kind": "sentence-pattern",
      "term": "Rarely ... as ...",
      "meaningZh": "很少有...像...",
      "difficulty": 2,
