      "synonyms": ["Obviously,", "Clearly,", "Evidently,"]
    },
    {
      "id": "emphasis-025",
      "kind": "sentence-pattern",
      "term": "The bottom line is simple: ...",
      "meaningZh": "底線很簡單：...",
