{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "devCommand": "npm run dev",
  "cleanUrls": true,
  "git": {
    "ignorePaths": ["README.md", "*.md", "docs/**", ".gitignore", "LICENSE"]
  },
  "redirects": [
    {
      "source": "/:page.html",
      "destination": "/:page",
      "permanent": true
    },
    {
      "source": "/blog/:slug.html",
      "destination": "/blog/:slug",
      "permanent": true
    },
    {
      "source": "/jable",
      "destination": "https://jable.tv/",
      "permanent": false
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "has": [
        { "type": "host", "value": "dbest-v1-git-main-1fus-projects.vercel.app" }
      ],
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex" }
      ]
    },
    {
      "source": "/(.*)",
      "has": [
        { "type": "host", "value": "dbest-v1-gsqxylviq-1fus-projects.vercel.app" }
      ],
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex" }
      ]
    }
  ]
}