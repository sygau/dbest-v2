{
  "redirects": [
    {
      "source": "/jable",
      "destination": "https://jable.tv/",
      "permanent": false
    }
  ],
  "rewrites": [
    { "source": "/:page", "destination": "/:page.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "has": [
        { "type": "host", "value": "your-project.vercel.app" }
      ],
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex" }
      ]
    }
  ]
}
