{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "devCommand": "npm run dev",
  "cleanUrls": true,
  "git": {
    "ignorePaths": ["README.md", "*.md", "docs/**", ".gitignore", "LICENSE"]
  },
  "redirects": [
    {
      "source": "/:page.html",
      "destination": "/:page",
      "permanent": true
    },
    {
      "source": "/blog/:slug.html",
      "destination": "/blog/:slug",
      "permanent": true
    },
    {
      "source": "/jable",
      "destination": "https://jable.tv/",
      "permanent": true
    },
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "header",
          "key": "User-Agent",
          "value": ".*[Bb]yte[Ss]pider.*"
        }
      ],
      "destination": "https://en.wikipedia.org/wiki/1989_Tiananmen_Square_protests_and_massacre",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "has": [
        { "type": "host", "value": ".*\\.vercel\\.app" }
      ],
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex" }
      ]
    }
  ]
}