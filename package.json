{
  "private": true,
  "name": "dbest-v1",
  "version": "1.0.0",
  "description": "DSE.BEST - Hong Kong DSE Past Papers and Blog",
  "main": "contentful/contentful.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:cloudflare": "node scripts/build-cloudflare.js",
    "build:vercel": "npm run build",
    "build:full": "npm run prebuild && npm run css:build && npm run obfuscate:appendlinksx && next build",
    "prebuild": "node scripts/generate-blog-data.js",
    "prebuild:safe": "node -e \"console.log('Checking for blog data...'); try { require('./data/blog-index.json'); console.log('✅ Blog data found'); } catch(e) { console.log('⚠️  Blog data not found, using static data'); }\"",
    "start": "next start",
    "lint": "next lint",
    "export": "npm run prebuild && next build && next export",
    "meta": "node scripts/updateMeta.js",
    "blog:sync": "node scripts/generate-blog-data.js",
    "css:build": "node scripts/combine-css.js",
    "css:test": "node scripts/test-css-bundle.js",
    "sitemap": "node scripts/generate-sitemap.js",
    "cutoff:process": "node scripts/process-cutoff-data.js",
    "cutoff:validate": "node scripts/validate-csv-structure.js",
    "obfuscate:appendlinksx": "node scripts/obfuscate-appendlinksx.js",
    "views:check": "node scripts/check-view-counts.js",
    "views:inflate": "node scripts/inflate-view-counts.js",
    "views:reset": "node scripts/reset-view-counts.js"
  },
  "dependencies": {
    "@contentful/rich-text-html-renderer": "^16.6.10",
    "@contentful/rich-text-types": "^16.8.5",
    "@types/node": "^24.2.0",
    "@types/react": "^19.1.9",
    "ably": "^1.2.48",
    "bootstrap": "^5.3.2",
    "contentful": "^10.15.1",
    "framer-motion": "^12.23.12",
    "fs-extra": "^11.1.1",
    "next": "^15.4.5",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-icons": "^5.5.0",
    "redis": "^5.8.2",
    "typescript": "^5.9.2"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/1fu/dbest-v1.git"
  },
  "keywords": [
    "dse",
    "hong-kong",
    "past-papers",
    "education",
    "blog",
    "contentful"
  ],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/1fu/dbest-v1/issues"
  },
  "homepage": "https://github.com/1fu/dbest-v1#readme",
  "devDependencies": {
    "clean-css": "^5.3.3",
    "csv-parser": "^3.0.0",
    "javascript-obfuscator": "^4.1.1"
  }
}
