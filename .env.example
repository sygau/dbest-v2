# Runtime environment
# NODE_ENV is typically set by the platform (development|production)
# NODE_ENV=development

# --- Server-side toggles ---
# Enable global maintenance mode (true/false or 1/0)
MAINTENANCE_MODE=false
# Optional maintenance page message
MAINTENANCE_MESSAGE=
# Emergency kill switch for certain features (true/false or 1/0)
MAYDAY=false

# --- Client-side public config (exposed to browser) ---
# Navigation mode for the site UI: traditional | traditional_new (fallbacks to default if unset)
NEXT_PUBLIC_NAVIGATION_MODE=traditional
# Disable chat UI globally (true/false)
NEXT_PUBLIC_CHAT_DISABLED=false
# Message displayed when chat is disabled
NEXT_PUBLIC_CHAT_DISABLED_MESSAGE=Chat Temporarily Unavailable

# --- Contentful CMS (required for blog/content) ---
# Referenced in README and Cloudflare config; required if using Contentful data
CONTENTFUL_SPACE_ID=
CONTENTFUL_ENVIRONMENT=master
CONTENTFUL_ACCESS_TOKEN=
CONTENTFUL_PREVIEW_ACCESS_TOKEN=

# --- Optional/legacy API utilities ---
# Redis connection URL (used by backup scripts under api-backup/)
REDIS_URL=
# Moderator secret for legacy chat auth (api-backup/)
MOD_SECRET_KEY=
# Logging / security analysis examples (from docs)
LOGFLARE_API_KEY=
JWT_SECRET=
